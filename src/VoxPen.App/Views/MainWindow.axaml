<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:VoxPen.App.ViewModels"
        mc:Ignorable="d" d:DesignWidth="720" d:DesignHeight="480"
        x:Class="VoxPen.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="声写 (VoxPen)"
        Width="720" Height="480"
        MinWidth="520" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/tray.ico">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="16">

        <!-- 标题 + 状态灯 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <Ellipse Width="14" Height="14" Fill="{Binding StateBrush}" />
            <TextBlock Text="{Binding StateLabel}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Text="•" Opacity="0.4" VerticalAlignment="Center" />
            <TextBlock Text="{Binding ShortcutHint}" Opacity="0.7" VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="1"
                IsVisible="{Binding HasStartupError}"
                Background="#33D32F2F"
                BorderBrush="#FFD32F2F"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Margin="0,10,0,2">
            <SelectableTextBlock Text="{Binding StartupError}"
                                 Foreground="#FFD32F2F"
                                 TextWrapping="Wrap" />
        </Border>

        <!-- 分隔 -->
        <Border Grid.Row="2" Height="1" Background="{DynamicResource SystemBaseLowColor}" Margin="0,12,0,12" />

        <!-- 主内容：TabControl -->
        <TabControl Grid.Row="3">
            <TabItem Header="识别历史">
                <Grid RowDefinitions="*,Auto">
                    <ListBox Grid.Row="0"
                             ItemsSource="{Binding History}"
                             SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                               Opacity="0.5" FontSize="11" />
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button Content="复制最新" Command="{Binding CopyLatestCommand}" />
                        <Button Content="清空历史" Command="{Binding ClearHistoryCommand}" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="设置">
                <ScrollViewer>
                    <StackPanel Spacing="10">
                        <TextBlock Text="快捷键" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ShortcutDisplay}" FontSize="16" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="录制快捷键" Command="{Binding StartShortcutRecordingCommand}"
                                    IsEnabled="{Binding CanEditSettings}" />
                            <Button Content="取消录制" Command="{Binding CancelShortcutRecordingCommand}"
                                    IsEnabled="{Binding IsRecordingShortcut}" />
                        </StackPanel>
                        <TextBlock Text="{Binding ShortcutRecordingStatus}" Opacity="0.75" TextWrapping="Wrap" />
                        <TextBlock Text="识别模型" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <ComboBox ItemsSource="{Binding AsrModels}"
                                  SelectedItem="{Binding SelectedAsrModel}"
                                  IsEnabled="{Binding CanEditSettings}"
                                  HorizontalAlignment="Left" MinWidth="260">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" />
                                        <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.65" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="{Binding SelectedAsrModel.Description}" Opacity="0.75" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="下载模型" Command="{Binding DownloadSelectedModelCommand}"
                                    IsEnabled="{Binding CanEditSettings}" />
                            <Button Content="取消下载" Command="{Binding CancelModelDownloadCommand}"
                                    IsEnabled="{Binding IsModelDownloading}" />
                        </StackPanel>
                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding ModelDownloadPercent}"
                                     IsVisible="{Binding IsModelDownloading}" Height="8" />
                        <TextBlock Text="{Binding ModelDownloadStatus}" Opacity="0.75" TextWrapping="Wrap" />

                        <StackPanel Spacing="8" IsVisible="{Binding ShouldShowPunctuationDownload}">
                            <TextBlock Text="标点模型（可选）" FontWeight="SemiBold" Margin="0,8,0,0" />
                            <TextBlock Text="当前识别模型不自带标点；未安装时仍可使用，但识别结果没有自动标点。"
                                       Opacity="0.75" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="下载标点模型" Command="{Binding DownloadPunctuationModelCommand}"
                                        IsEnabled="{Binding CanEditSettings}" />
                                <Button Content="取消下载" Command="{Binding CancelPunctuationDownloadCommand}"
                                        IsEnabled="{Binding IsPunctuationModelDownloading}" />
                            </StackPanel>
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding PunctuationDownloadPercent}"
                                         IsVisible="{Binding IsPunctuationModelDownloading}" Height="8" />
                            <TextBlock Text="{Binding PunctuationDownloadStatus}" Opacity="0.75" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding PunctuationModelStatusIcon}" FontSize="18" />
                            <TextBlock Text="{Binding PunctuationModelStatusText}" Opacity="0.75" TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBlock Text="模型状态" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding ModelStatusIcon}" FontSize="18" />
                        <TextBlock Text="{Binding ModelStatusText}" Opacity="0.75" TextWrapping="Wrap" />

                        <TextBlock Text="上屏模式" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding OutputModeLabel}" Opacity="0.75" />

                        <TextBlock Text="强制粘贴应用" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding PasteAppsLabel}" Opacity="0.75" TextWrapping="Wrap" />

                        <Border Height="1" Background="{DynamicResource SystemBaseLowColor}" Margin="0,12,0,12" />
                        <Button Content="保存并应用"
                                Command="{Binding SaveSettingsCommand}"
                                IsEnabled="{Binding CanSaveSettings}"
                                HorizontalAlignment="Left" />
                        <TextBlock Text="{Binding SettingsSaveStatus}"
                                   Opacity="0.75"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="保存后立即应用快捷键和模型；其他高级配置仍可手工编辑 config.json。"
                                   Opacity="0.55" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="日志">
                <TextBox Text="{Binding LogText, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas,Menlo,monospace"
                         FontSize="12" />
            </TabItem>
        </TabControl>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="暂停/继续" Command="{Binding TogglePauseCommand}" />
            <Button Content="最小化到托盘" Command="{Binding HideToTrayCommand}" />
            <Button Content="退出" Command="{Binding ExitCommand}" />
        </StackPanel>
    </Grid>
</Window>
