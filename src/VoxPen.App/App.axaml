<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="VoxPen.App.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/tray.ico"
                      ToolTipText="声写 (VoxPen)"
                      Clicked="OnTrayClicked">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="显示主窗口" Click="OnShowMainWindow" />
                        <NativeMenuItem Header="暂停/继续监听" Click="OnTogglePause" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="打开配置文件夹" Click="OnOpenConfigFolder" />
                        <NativeMenuItem Header="关于" Click="OnAbout" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="退出" Click="OnExit" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
